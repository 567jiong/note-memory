{
  "openapi": "3.0.3",
  "info": {
    "title": "阅读记忆助手 API",
    "description": "Reading Memory Agent — 帮助长篇小说读者在中断后快速恢复阅读状态，严格无剧透。\n\n## 核心概念\n- 上传 TXT 小说 → 自动拆分章节 → AI 逐章总结 → 按阅读进度生成回顾\n- 所有 AI 调用严格限制在用户当前阅读进度以内，绝不剧透",
    "version": "1.0.0",
    "contact": {
      "name": "Reading Memory Agent"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "本地开发环境"
    }
  ],
  "tags": [
    {
      "name": "小说管理",
      "description": "上传、查看、管理小说"
    },
    {
      "name": "阅读进度",
      "description": "跟踪用户阅读进度"
    },
    {
      "name": "AI 解析",
      "description": "触发 AI 对章节进行总结和人物/事件提取"
    },
    {
      "name": "阅读回顾",
      "description": "生成和获取无剧透阅读恢复回顾"
    }
  ],
  "paths": {
    "/api/novels": {
      "post": {
        "tags": ["小说管理"],
        "summary": "上传 TXT 小说",
        "description": "上传 TXT 文件，系统自动识别章节标题并拆分章节，同时触发后台 AI 异步解析。",
        "operationId": "uploadNovel",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file"],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "TXT 格式小说文件"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "上传成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "novel": { "$ref": "#/components/schemas/Novel" },
                    "message": {
                      "type": "string",
                      "example": "小说上传成功，正在后台进行 AI 解析..."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "文件缺失或格式错误",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": {
            "description": "服务器内部错误",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["小说管理"],
        "summary": "获取小说列表",
        "description": "返回所有已上传的小说，按更新时间倒序排列。",
        "operationId": "listNovels",
        "responses": {
          "200": {
            "description": "小说列表",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "novels": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Novel" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/novels/{id}": {
      "get": {
        "tags": ["小说管理"],
        "summary": "获取小说详情",
        "description": "返回小说基本信息、章节列表和阅读进度。",
        "operationId": "getNovel",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "小说 ID",
            "schema": { "type": "integer", "format": "int64", "example": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "小说详情",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "novel": { "$ref": "#/components/schemas/Novel" },
                    "chapters": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Chapter" }
                    },
                    "progress": {
                      "anyOf": [
                        { "$ref": "#/components/schemas/ReadingProgress" },
                        { "type": "null" }
                      ]
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "无效的 ID",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "404": {
            "description": "小说不存在",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/novels/{id}/progress": {
      "put": {
        "tags": ["阅读进度"],
        "summary": "更新阅读进度",
        "description": "设置用户当前读到第几章。进度必须在 [1, 总章节数] 范围内。",
        "operationId": "updateProgress",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "小说 ID",
            "schema": { "type": "integer", "format": "int64", "example": 1 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["current_chapter"],
                "properties": {
                  "current_chapter": {
                    "type": "integer",
                    "description": "当前阅读到的章节号",
                    "minimum": 1,
                    "example": 500
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "进度已更新" },
                    "current_chapter": { "type": "integer", "example": 500 }
                  }
                }
              }
            }
          },
          "400": {
            "description": "参数无效（章节超出范围等）",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/novels/{id}/parse": {
      "post": {
        "tags": ["AI 解析"],
        "summary": "触发 AI 解析",
        "description": "对未解析的章节启动后台 AI 总结和人物/事件提取。每次并发处理 3 章，异步执行。",
        "operationId": "triggerParse",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "小说 ID",
            "schema": { "type": "integer", "format": "int64", "example": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "解析已触发",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "AI 解析已开始" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/novels/{id}/recap": {
      "post": {
        "tags": ["阅读回顾"],
        "summary": "生成阅读恢复回顾",
        "description": "根据用户当前阅读进度，生成无剧透阅读恢复回顾。包含 30 秒速览版和 3 分钟详细版。\n\n**核心规则：** 只使用第 1 章到当前进度章节的数据，绝不涉及后续内容。\n\n结果会缓存，进度不变时重复调用不会消耗 API 额度。",
        "operationId": "generateRecap",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "小说 ID",
            "schema": { "type": "integer", "format": "int64", "example": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "回顾内容",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "recap": {
                      "type": "string",
                      "description": "Markdown 格式的回顾内容",
                      "example": "### 📖 30 秒速览版\n主角韩立当前是筑基期修士，正在乱星海寻找突破金丹的机缘...\n\n### 📚 3 分钟详细版\n..."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "无效的小说 ID 或未设置进度",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": {
            "description": "AI 调用失败",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["阅读回顾"],
        "summary": "获取缓存的回顾",
        "description": "获取之前生成的回顾（不调用 AI，直接读缓存）。按当前阅读进度匹配。",
        "operationId": "getRecap",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "小说 ID",
            "schema": { "type": "integer", "format": "int64", "example": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "缓存的回顾",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "recap": {
                      "type": "string",
                      "description": "Markdown 格式的回顾内容"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "暂无缓存，需先生成",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Novel": {
        "type": "object",
        "description": "小说基本信息",
        "properties": {
          "id": { "type": "integer", "format": "int64", "example": 1 },
          "title": { "type": "string", "description": "小说标题", "example": "凡人修仙传" },
          "author": { "type": "string", "description": "作者", "example": "忘语" },
          "total_chapters": { "type": "integer", "description": "总章节数", "example": 1500 },
          "created_at": { "type": "string", "format": "date-time", "description": "上传时间" },
          "updated_at": { "type": "string", "format": "date-time", "description": "最后更新时间" }
        }
      },
      "Chapter": {
        "type": "object",
        "description": "章节信息",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "novel_id": { "type": "integer", "format": "int64" },
          "chapter_number": { "type": "integer", "description": "章节号", "example": 500 },
          "title": { "type": "string", "description": "章节标题（从 TXT 解析得到）", "example": "第500章 乱星海" },
          "content": { "type": "string", "description": "章节正文（最多 5000 字）" },
          "summary": { "type": "string", "description": "AI 生成的章节摘要。为空表示未解析。" },
          "characters": {
            "type": "array",
            "description": "AI 提取的人物列表",
            "items": { "$ref": "#/components/schemas/CharacterInfo" }
          },
          "events": {
            "type": "array",
            "description": "AI 提取的事件列表",
            "items": { "$ref": "#/components/schemas/EventInfo" }
          },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "CharacterInfo": {
        "type": "object",
        "description": "人物信息",
        "properties": {
          "name": { "type": "string", "description": "人物姓名", "example": "韩立" },
          "aliases": {
            "type": "array",
            "items": { "type": "string" },
            "description": "别名/称号",
            "example": ["韩跑跑", "厉飞雨"]
          },
          "status": { "type": "string", "description": "当前状态/境界", "example": "筑基期修士" },
          "first_appearance": { "type": "integer", "description": "首次出场章节", "example": 1 }
        }
      },
      "EventInfo": {
        "type": "object",
        "description": "事件信息",
        "properties": {
          "title": { "type": "string", "description": "事件名称", "example": "获得掌天瓶" },
          "participants": {
            "type": "array",
            "items": { "type": "string" },
            "description": "参与人物"
          },
          "summary": { "type": "string", "description": "事件简述" },
          "impact": { "type": "string", "description": "事件影响", "example": "开启修仙之路" },
          "chapter_num": { "type": "integer", "description": "发生章节", "example": 7 }
        }
      },
      "ReadingProgress": {
        "type": "object",
        "description": "阅读进度",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "novel_id": { "type": "integer", "format": "int64" },
          "current_chapter": { "type": "integer", "description": "当前阅读章节", "example": 500 },
          "updated_at": { "type": "string", "format": "date-time", "description": "最后更新进度时间" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "description": "错误信息" }
        }
      }
    }
  }
}
