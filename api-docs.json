{
  "openapi": "3.0.3",
  "info": {
    "title": "阅读记忆助手 API (Phase 2 — RAG + Hybrid Search)",
    "description": "Reading Memory Agent — 基于 pgvector(1024维) + tsvector 全文检索的混合搜索。核心：上传 TXT → AI 章节总结 → embedding 向量化 + 全文索引 → 混合检索 → 无剧透回顾/问答。支持 Chat 和 Embedding 独立 API 配置。",
    "version": "2.1.0"
  },
  "servers": [{ "url": "http://localhost:8080", "description": "本地开发" }],
  "tags": [
    { "name": "小说管理" },
    { "name": "阅读进度" },
    { "name": "AI 解析" },
    { "name": "阅读回顾" },
    { "name": "RAG 检索" }
  ],
  "paths": {
    "/api/novels": {
      "post": {
        "tags": ["小说管理"],
        "summary": "上传 TXT 小说",
        "operationId": "uploadNovel",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file"],
                "properties": {
                  "file": { "type": "string", "format": "binary", "description": "TXT 格式小说文件" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "上传成功，后台自动触发 AI 解析（总结 + embedding + 全文索引 + 别名）",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "novel": { "$ref": "#/components/schemas/Novel" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["小说管理"],
        "summary": "获取小说列表",
        "operationId": "listNovels",
        "responses": {
          "200": {
            "description": "小说列表",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "novels": { "type": "array", "items": { "$ref": "#/components/schemas/Novel" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/novels/{id}": {
      "get": {
        "tags": ["小说管理"],
        "summary": "获取小说详情 + 章节 + 进度",
        "operationId": "getNovel",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "responses": {
          "200": {
            "description": "小说详情",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "novel": { "$ref": "#/components/schemas/Novel" },
                    "chapters": { "type": "array", "items": { "$ref": "#/components/schemas/Chapter" } },
                    "progress": { "$ref": "#/components/schemas/ReadingProgress" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/novels/{id}/progress": {
      "put": {
        "tags": ["阅读进度"],
        "summary": "更新阅读进度",
        "operationId": "updateProgress",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["current_chapter"],
                "properties": {
                  "current_chapter": { "type": "integer", "minimum": 1, "example": 500 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "进度已更新",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "current_chapter": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/novels/{id}/parse": {
      "post": {
        "tags": ["AI 解析"],
        "summary": "触发 AI 解析（总结 + embedding + 全文索引 + 别名）",
        "description": "异步批量处理：AI 总结 → 生成 embedding(1024维) → 全文索引(tsvector+分词) → 角色别名写入。并发 3 章。",
        "operationId": "triggerParse",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "responses": {
          "200": {
            "description": "解析已开始",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "message": { "type": "string" } }
                }
              }
            }
          }
        }
      }
    },
    "/api/novels/{id}/embed": {
      "post": {
        "tags": ["AI 解析"],
        "summary": "回填空 embedding 字段（从章节内容，不调 LLM）",
        "description": "遍历所有 embedding IS NULL 的章节，取内容截断至 ≤400 字（适配 512 token 限制），直接调用 Embedding API 生成向量。不消耗 Chat API 额度。并发 3 章。",
        "operationId": "triggerFillEmbeddings",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "responses": {
          "200": {
            "description": "回填已开始",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "message": { "type": "string", "example": "Embedding 回填已开始（使用章节内容，≤400字截断）" } }
                }
              }
            }
          }
        }
      }
    },
    "/api/novels/{id}/recap": {
      "post": {
        "tags": ["阅读回顾"],
        "summary": "生成阅读恢复回顾（RAG 增强版）",
        "description": "使用混合检索（语义 + 全文 + 别名扩展）检索最相关章节，生成无剧透回顾。30s 版 + 3min 版。",
        "operationId": "generateRecap",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "responses": {
          "200": {
            "description": "回顾内容（Markdown）",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "recap": { "type": "string", "description": "Markdown 格式回顾" }
                  }
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["阅读回顾"],
        "summary": "获取缓存回顾",
        "operationId": "getRecap",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "responses": {
          "200": {
            "description": "缓存的回顾",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "recap": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/novels/{id}/ask": {
      "post": {
        "tags": ["RAG 检索"],
        "summary": "无剧透智能问答",
        "description": "用户提问 → 别名扩展 → 混合检索（语义 + 全文） → LLM 生成无剧透答案。Embedding 不可用时自动降级为纯全文检索。",
        "operationId": "askQuestion",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["question"],
                "properties": {
                  "question": { "type": "string", "description": "用户问题", "example": "主角现在什么境界？" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "AI 无剧透回答",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "question": { "type": "string" },
                    "answer": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/novels/{id}/search": {
      "get": {
        "tags": ["RAG 检索"],
        "summary": "混合搜索章节（语义 + 全文 + 别名扩展）",
        "description": "加权融合 pgvector 语义搜索(0.7) 和 tsvector 全文搜索(0.3)。自动扩展角色别名。Embedding 不可用时降级为纯全文检索。",
        "operationId": "searchChapters",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "q", "in": "query", "required": true, "description": "搜索关键词", "schema": { "type": "string", "example": "掌天瓶" } }
        ],
        "responses": {
          "200": {
            "description": "搜索结果。mode=hybrid 时含语义分+全文分，mode=text_only 时仅全文分。",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "query": { "type": "string" },
                    "mode": { "type": "string", "enum": ["hybrid", "text_only"], "description": "hybrid=语义+全文 / text_only=仅全文降级" },
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "chapter": { "$ref": "#/components/schemas/Chapter" },
                          "semantic_score": { "type": "number", "description": "向量相似度 (0~1)，text_only 模式下为 0" },
                          "text_score": { "type": "number", "description": "全文匹配分" },
                          "final_score": { "type": "number", "description": "加权最终分 (semantic*0.7 + text*0.3)" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Novel": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "title": { "type": "string", "example": "凡人修仙传" },
          "total_chapters": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "Chapter": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "novel_id": { "type": "integer", "format": "int64" },
          "chapter_number": { "type": "integer" },
          "title": { "type": "string" },
          "summary": { "type": "string", "description": "AI 生成摘要（空=未解析）" },
          "characters": { "type": "array", "items": { "$ref": "#/components/schemas/CharacterInfo" } },
          "events": { "type": "array", "items": { "$ref": "#/components/schemas/EventInfo" } }
        }
      },
      "CharacterInfo": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "status": { "type": "string" },
          "first_appearance": { "type": "integer" }
        }
      },
      "EventInfo": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "participants": { "type": "array", "items": { "type": "string" } },
          "summary": { "type": "string" },
          "impact": { "type": "string" },
          "chapter_num": { "type": "integer" }
        }
      },
      "ReadingProgress": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "novel_id": { "type": "integer", "format": "int64" },
          "current_chapter": { "type": "integer" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      }
    }
  }
}
