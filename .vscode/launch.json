{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🚀 Launch Server",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/server",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "🧪 Launch Package",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${fileDirname}"
        },
        {
            "name": "📎 Attach to Process",
            "type": "go",
            "request": "attach",
            "mode": "local",
            // "processId": "${command:pickProcess}"
            "port": 8080,
        }
    ]
}
