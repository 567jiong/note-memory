# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=note_memory

# OpenAI API (compatible with deepseek, etc.)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=deepseek-v4-pro
# Embedding API — DeepSeek 不支持 /embeddings，需单独配一个支持 OpenAI 格式的地址
# 例如用硅基流动(SiliconFlow, https://api.siliconflow.cn/v1) 有免费 embedding 额度
OPENAI_EMBEDDING_API_KEY= 
# 空则复用 OPENAI_API_KEY
OPENAI_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1  
# 空则复用 OPENAI_BASE_URL
OPENAI_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
# 即使不配 embedding API，搜索也会自动降级到全文检索（分词匹配），功能不受影响

# Neo4j (可选项 — 不配则跳过知识图谱功能)
# 开发环境: docker run -d --name neo4j-note -p 7474:7474 -p 7687:7687 -e NEO4J_AUTH=neo4j/password neo4j:5-community
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Server
SERVER_PORT=8080
