# ═══════════════════════════════════════════════════════════
# 阅读记忆助手 (Reading Memory Agent) 配置文件
# 复制此文件为 .env 并填入你的配置
# cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── PostgreSQL 数据库 ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=note_memory

# ── LLM 对话 API ──────────────────────────────────────────
# 支持任意 OpenAI 兼容 API（DeepSeek、OpenAI、硅基流动等）
# 推荐 DeepSeek：https://api.deepseek.com/v1
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=deepseek-chat

# ── Embedding API（向量化） ──────────────────────────────
# DeepSeek 不支持 /embeddings 端点，需单独配置
# 推荐硅基流动（免费额度）：https://api.siliconflow.cn/v1
OPENAI_EMBEDDING_API_KEY=
# 空则复用 OPENAI_API_KEY
OPENAI_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# 空则复用 OPENAI_BASE_URL
OPENAI_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
# 即使不配 embedding API，搜索也会自动降级到全文检索（分词匹配），功能不受影响

# ── Reranker API（交叉编码器精排，可选） ──────────────────
# 不配则使用 RRF-only 排序
# 推荐硅基流动（免费额度）
RERANK_API_KEY=
RERANK_BASE_URL=https://api.siliconflow.cn/v1
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ── Neo4j 图数据库（可选） ────────────────────────────────
# 不配则自动跳过知识图谱功能
# Docker 快速启动: docker run -d --name neo4j-note -p 7474:7474 -p 7687:7687 -e NEO4J_AUTH=neo4j/password neo4j:5-community
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── 服务端口 ──────────────────────────────────────────────
SERVER_PORT=8080
